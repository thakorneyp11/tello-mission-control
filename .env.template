# Tello Web Controller - Environment Configuration
# Copy this file to .env and adjust values as needed

# Drone connection
TELLO_TELLO_HOST=192.168.10.1
TELLO_USE_MOCK_DRONE=true

# Backend server
TELLO_API_PORT=8000

# Frontend
TELLO_FRONTEND_PORT=3000

# Telemetry
TELLO_TELEMETRY_POLL_HZ=4.0

# Video streaming
TELLO_VIDEO_FPS=30
TELLO_VIDEO_JPEG_QUALITY=70

# CORS (JSON array of allowed origins)
TELLO_CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
